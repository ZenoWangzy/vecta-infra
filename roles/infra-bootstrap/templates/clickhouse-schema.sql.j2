-- Managed by Ansible — do not edit on server directly.
CREATE TABLE IF NOT EXISTS audit_events (
  id UUID DEFAULT generateUUIDv4(),
  tenant_id LowCardinality(String),
  employee_id String,
  event_type LowCardinality(String),
  severity LowCardinality(String) DEFAULT 'info',
  resource String,
  payload String,
  ip_address String,
  request_id String,
  session_id String,
  created_at DateTime64(3, 'UTC'),
  ingested_at DateTime64(3, 'UTC') DEFAULT now64(3)
) ENGINE = MergeTree()
PARTITION BY toYYYYMM(created_at)
ORDER BY (tenant_id, created_at, event_type)
TTL toDateTime(created_at) + INTERVAL 2 YEAR;

CREATE MATERIALIZED VIEW IF NOT EXISTS audit_alerts_mv
ENGINE = MergeTree()
PARTITION BY toYYYYMMDD(created_at)
ORDER BY (tenant_id, created_at)
TTL toDateTime(created_at) + INTERVAL 90 DAY
AS SELECT *
FROM audit_events
WHERE severity IN ('warn', 'critical');
